{
    "$schema": "https://ograf.ebu.io/v1/specification/json-schemas/graphics/schema.json",
    "name": "Info Left Graphic",
    "description": "This graphic includes info text on the left side of the screen.",
    "id": "info-left-graphic",
    "version": "1",
    "supportsRealTime": true,
    "supportsNonRealTime": false,
    "main": "INFO_LEFT.mjs",
    "schema": {
        "type": "object",
        "properties": {
            "comment": {
                "type": "string",
                "title": "Nickname of this item on the rundown",
                "default": "[ Item nickname ]"
            },
            "instruction": {
                "v_spx": {
                    "ftype": "instruction"
                },
                "type": "string",
                "title": "Instruction",
                "default": "This template demonstrates the use of dropdowns to choose a file. Animated vector icons are in the lottie-subfolder."
            },
            "f0": {
                "type": "string",
                "title": "Text",
                "default": "Headquarters"
            },
            "f1": {
                "v_spx": {
                    "ftype": "filelist",
                    "assetfolder": "./resources/Info_left/lottie/",
                    "extension": "json"
                },
                "type": "string",
                "title": "Icon",
                "default": "./resources/Info_left/lottie/live-default.json"
            },
            "f99": {
                "v_spx": {
                    "ftype": "filelist",
                    "assetfolder": "./resources/Info_left/themes/",
                    "extension": "css"
                },
                "type": "string",
                "title": "Visual Theme",
                "default": "./resources/Info_left/themes/Default.css"
            }
        }
    },
    "v_spx": {
        "playserver": "OVERLAY",
        "playchannel": "1",
        "playlayer": "4",
        "webplayout": "4",
        "out": "manual",
        "uicolor": "3"
    }
}
